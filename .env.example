# ── Groq ──────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── LLM Settings ──────────────────────────────────────────
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0

# ── Playwright ────────────────────────────────────────────
BROWSER_HEADLESS=false          # true in production
BROWSER_SLOW_MO=50              # ms delay between actions (useful for debugging)
SCREENSHOT_DIR=./screenshots

# ── ChromaDB ──────────────────────────────────────────────
CHROMA_PERSIST_DIR=./memory_store

# ── FastAPI ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Streamlit ─────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
